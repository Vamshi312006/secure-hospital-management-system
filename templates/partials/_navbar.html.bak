<nav class="navbar">

    <!-- Left -->

    <div class="navbar__left">

        <button
            class="navbar__toggle"
            id="sidebar-toggle"
            aria-label="Toggle Sidebar"
        >
            <i data-lucide="menu"></i>
        </button>

        <a
            href="{{ url_for('dashboard.dashboard') }}"
            class="navbar__brand"
        >

            <div class="navbar__brand-logo">
                <i data-lucide="shield-plus"></i>
            </div>

            <div class="navbar__brand-text">

                <span class="navbar__title">
                    Secure Healthcare Platform
                </span>

                <span class="navbar__subtitle">
                    Security First
                </span>

            </div>

        </a>

    </div>

    <!-- Center -->

    <div class="navbar__center">

        {% if session.get("user_id") %}

        <div class="navbar__search">

            <i data-lucide="search"></i>

            <input
                type="text"
                placeholder="Search patients, doctors, appointments..."
            >

        </div>

        {% endif %}

    </div>

    <!-- Right -->

    <div class="navbar__right">

        {% if session.get("user_id") %}

            <button class="navbar__icon">
                <i data-lucide="bell"></i>
            </button>

            <button class="navbar__icon">
                <i data-lucide="shield"></i>
            </button>

            <div class="navbar__divider"></div>

            <div class="navbar__profile">

                <div class="navbar__avatar">

                    {{ session.get("username","A")[0]|upper }}

                </div>

                <div class="navbar__user">

                    <span class="navbar__username">

                        {{ session.get("username") }}

                    </span>

                    <small>

                        {{ session.get("role","User") }}

                    </small>

                </div>

            </div>

            <a
                href="{{ url_for('auth.logout') }}"
                class="navbar__logout"
            >

                <i data-lucide="log-out"></i>

                <span>Logout</span>

            </a>

        {% else %}

            <a
                href="{{ url_for('auth.login_page') }}"
                class="navbar__logout"
            >

                <i data-lucide="log-in"></i>

                <span>Login</span>

            </a>

        {% endif %}

    </div>

</nav>
