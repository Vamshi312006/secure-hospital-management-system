{% extends "layouts/base.html" %}

{% block title %}
Dashboard
{% endblock %}

{% block page_css %}
<link
    rel="stylesheet"
    href="{{ url_for('static', filename='css/pages/dashboard.css') }}"
>
{% endblock %}

{% block content %}

<div class="page-header">

    <div>

        <span class="breadcrumb">
            Home /
            <strong>Dashboard</strong>
        </span>

        <h1>Operations Dashboard</h1>

        <p>
            Operational overview of the Secure Healthcare Platform.
        </p>

    </div>

    </div>

<section class="dashboard-grid">

    <div class="stat-card">

        <div class="stat-card-top">

            <div class="stat-icon">
                <i data-lucide="users"></i>
            </div>

            <span class="badge badge-success">
                Live
            </span>

        </div>

        <h3>Total Patients</h3>

        <span>{{ metrics.patient_count }}</span>

        <small>Registered patients</small>

    </div>

    <div class="stat-card">

        <div class="stat-card-top">

            <div class="stat-icon">
                <i data-lucide="stethoscope"></i>
            </div>

            <span class="badge badge-success">
                Live
            </span>

        </div>

        <h3>Doctors</h3>

        <span>{{ metrics.doctor_count }}</span>

        <small>Active medical staff</small>

    </div>

    <div class="stat-card">

        <div class="stat-card-top">

            <div class="stat-icon">
                <i data-lucide="calendar-days"></i>
            </div>

            <span class="badge badge-primary">
                Today
            </span>

        </div>

        <h3>Appointments</h3>

        <span>{{ metrics.today_appointments }}</span>

        <small>Scheduled today</small>

    </div>

    <div class="stat-card">

        <div class="stat-card-top">

            <div class="stat-icon">
                <i data-lucide="monitor-check"></i>
            </div>

            <span class="badge badge-success">
                Active
            </span>

        </div>

        <h3>Sessions</h3>

        <span>{{ metrics.active_sessions }}</span>

        <small>Authenticated sessions</small>

    </div>

    <div class="stat-card">

        <div class="stat-card-top">

            <div class="stat-icon">
                <i data-lucide="shield-alert"></i>
            </div>

            <span class="badge badge-warning">
                Monitor
            </span>

        </div>

        <h3>Failed Logins</h3>

        <span>{{ metrics.failed_logins }}</span>

        <small>Authentication failures</small>

    </div>

    <div class="stat-card">

        <div class="stat-card-top">

            <div class="stat-icon">
                <i data-lucide="history"></i>
            </div>

            <span class="badge badge-primary">
                Live
            </span>

        </div>

        <h3>Audit Events</h3>

        <span>{{ metrics.audit_events }}</span>

        <small>Recorded events</small>

    </div>

</section>

<section class="dashboard-panels">

    <div class="panel">

        <div class="panel-header">

            <h2>Recent Audit Events</h2>

            <a
                href="{{ url_for('audit.index') }}"
                class="btn btn-secondary btn-sm"
            >
                View All
            </a>

        </div>

        <div class="panel-body">

            <table class="table">

                <thead>

                    <tr>

                        <th>Time</th>

                        <th>Action</th>

                        <th>Resource</th>

                        <th>Status</th>

                    </tr>

                </thead>

                <tbody>

                {% for log in metrics.recent_audit_events %}

                    <tr>

                        <td>

                            {{ log.created_at.strftime("%H:%M") }}

                        </td>

                        <td>

                            {{ log.action }}

                        </td>

                        <td>

                            {{ log.resource }}

                        </td>

                        <td>

                            <span class="badge badge-success">

                                {{ log.status }}

                            </span>

                        </td>

                    </tr>

                {% else %}

                    <tr>

                        <td colspan="4" class="table-empty">

                            No audit events available.

                        </td>

                    </tr>

                {% endfor %}

                </tbody>

            </table>

        </div>

    </div>

    
<div class="panel">

    <div class="panel-header">

        <h2>Security Status</h2>

    </div>

    <div class="panel-body">

        <div class="security-item">

            <span>System Health</span>

            <strong class="text-success">
                Healthy
            </strong>

        </div>

        <div class="security-item">

            <span>Active Sessions</span>

            <strong>
                {{ metrics.active_sessions }}
            </strong>

        </div>

        <div class="security-item">

            <span>Failed Logins</span>

            <strong>
                {{ metrics.failed_logins }}
            </strong>

        </div>

        <div class="security-item">

            <span>Audit Events</span>

            <strong>
                {{ metrics.audit_events }}
            </strong>

        </div>

        <div class="security-item">

            <span>Security Alerts</span>

            <strong>
                {{ metrics.security_alerts }}
            </strong>

        </div>

    </div>

</div>

</section>


{% endblock %}
