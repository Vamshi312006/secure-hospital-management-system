{% extends "layouts/base.html" %}

{% block title %}Billing{% endblock %}

{% block content %}

<div class="page-header">

    <h1>Invoices</h1>

</div>

<div class="panel">

    <table class="table">

        <thead>

            <tr>

                <th>Invoice</th>

                <th>Patient</th>

                <th>Total</th>

                <th>Status</th>

            </tr>

        </thead>

        <tbody>

        {% for invoice in invoices %}

            <tr>

                <td>

                    <a href="{{ url_for('billing.view', invoice_id=invoice.id) }}">
                        {{ invoice.invoice_number }}
                    </a>

                </td>

                <td>

                    {{ invoice.patient.first_name }}
                    {{ invoice.patient.last_name }}

                </td>

                <td>

                    ₹ {{ invoice.total }}

                </td>

                <td>

                    {{ invoice.status }}

                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

</div>

{% endblock %}
